@namespace AirbnbKeywordFinder.Web.Components.Pages

<div class="glass rounded-xl overflow-hidden card-hover animate-fade-in">
    <!-- Image -->
    <div class="relative h-48 overflow-hidden bg-gradient-to-br from-gray-200 to-gray-300">
        @if (Match.Property.Images.Count > 0)
        {
            <img src="@Match.Property.Images.First()" alt="@Match.Property.Title" 
                 class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" loading="lazy" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center">
                <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
            </div>
        }
        
        <!-- Badges -->
        @if (Match.Property.Badges.Count > 0)
        {
            <div class="absolute top-3 left-3 flex flex-wrap gap-2">
                @foreach (var badge in Match.Property.Badges.Take(2))
                {
                    <span class="px-2.5 py-1 text-xs font-semibold rounded-full shadow-lg
                                 @(badge.Contains("Superhost") ? "bg-brand-500 text-white" : "bg-white text-gray-800")">
                        @badge
                    </span>
                }
            </div>
        }

        <!-- Rating -->
        @if (Match.Property.Rating.HasValue)
        {
            <div class="absolute top-3 right-3 flex items-center gap-1 px-2.5 py-1 bg-white/95 rounded-full shadow-lg">
                <svg class="w-4 h-4 text-brand-500" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span class="text-sm font-semibold text-gray-900">@Match.Property.Rating.Value.ToString("F2")</span>
                @if (Match.Property.Reviews.HasValue)
                {
                    <span class="text-xs text-gray-500">(@Match.Property.Reviews)</span>
                }
            </div>
        }
    </div>

    <!-- Content -->
    <div class="p-5 space-y-4">
        <!-- Title & Location -->
        <div>
            <h3 class="font-semibold text-gray-900 line-clamp-2 mb-1">
                @(Match.FullDetails?.Title ?? Match.Property.Title)
            </h3>
            <p class="text-sm text-gray-500">@Match.Property.Description</p>
        </div>

        <!-- Accommodations -->
        @if (Match.Property.Accommodations.Count > 0)
        {
            <div class="flex items-center gap-3 text-sm text-gray-600">
                @foreach (var acc in Match.Property.Accommodations.Take(3))
                {
                    <span class="flex items-center gap-1">
                        @if (acc.Contains("bed"))
                        {
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h18M3 6h18M3 18h18"/>
                            </svg>
                        }
                        else if (acc.Contains("bath"))
                        {
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4"/>
                            </svg>
                        }
                        else
                        {
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        }
                        @acc
                    </span>
                }
            </div>
        }

        <!-- Amenities Preview -->
        @if (Match.FullDetails?.Amenities.Count > 0)
        {
            <div class="flex flex-wrap gap-2">
                @foreach (var amenity in Match.FullDetails.Amenities.Where(a => a.IsAvailable == true).Take(4))
                {
                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded-md">
                        <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        @amenity.Name
                    </span>
                }
            </div>
        }

        <!-- Matched Keywords -->
        <div class="p-3 bg-gradient-to-r from-purple-50 to-indigo-50 rounded-lg border border-purple-100">
            <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                    <span class="text-xs font-medium text-purple-700">Matched Keywords</span>
                </div>
                <span class="px-2 py-0.5 bg-purple-600 text-white text-xs font-bold rounded-full">
                    @Match.MatchedKeywords.Count match@(Match.MatchedKeywords.Count > 1 ? "es" : "")
                </span>
            </div>
            <div class="flex flex-wrap gap-1.5">
                @foreach (var keyword in Match.MatchedKeywords)
                {
                    <span class="px-2 py-0.5 bg-gradient-to-r from-purple-500 to-indigo-500 text-white text-xs font-medium rounded-full">
                        @keyword
                    </span>
                }
            </div>
        </div>

        <!-- Context -->
        @if (Match.MatchContexts.Count > 0)
        {
            <div class="p-3 bg-gray-50 rounded-lg border-l-2 border-brand-500">
                <p class="text-xs text-gray-500 mb-1">Found in description:</p>
                <p class="text-sm text-gray-700 italic line-clamp-2">
                    "@HighlightKeywords(Match.MatchContexts.First(), Match.MatchedKeywords)"
                </p>
            </div>
        }

        <!-- Host -->
        @if (Match.Host != null)
        {
            <div class="flex items-center gap-2 text-sm text-gray-600">
                <div class="w-8 h-8 bg-gradient-to-br from-brand-400 to-purple-500 rounded-full flex items-center justify-center text-white font-medium text-xs">
                    @(Match.Host.Name?.FirstOrDefault())
                </div>
                <div>
                    <span>Hosted by @Match.Host.Name</span>
                    @if (Match.Host.IsSuperhost == true)
                    {
                        <span class="ml-1 text-brand-500 font-medium">· Superhost</span>
                    }
                </div>
            </div>
        }

        <!-- Footer -->
        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
            <div>
                @if (Match.Property.Price != null)
                {
                    <span class="text-xl font-bold text-gray-900">@Match.Property.Price.TotalPrice</span>
                    <span class="text-sm text-gray-500 ml-1">@Match.Property.Price.Qualifier</span>
                }
            </div>
            <a href="@Match.Property.Link" target="_blank" rel="noopener" 
               class="inline-flex items-center gap-2 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-brand-500 transition-colors">
                View
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
            </a>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public MatchedProperty Match { get; set; } = null!;

    private MarkupString HighlightKeywords(string text, List<string> keywords)
    {
        var result = System.Web.HttpUtility.HtmlEncode(text);
        foreach (var keyword in keywords)
        {
            result = System.Text.RegularExpressions.Regex.Replace(
                result,
                $"({System.Text.RegularExpressions.Regex.Escape(keyword)})",
                "<mark class=\"bg-yellow-200 text-yellow-900 px-0.5 rounded\">$1</mark>",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        }
        return new MarkupString(result);
    }
}
